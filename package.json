{
  "name": "rich-editor-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo root for @teamsparta/rich-editor and its playground",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
