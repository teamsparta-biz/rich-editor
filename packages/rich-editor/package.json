{
  "name": "@teamsparta/rich-editor",
  "version": "0.4.0",
  "description": "팀스파르타 공용 TipTap 기반 리치텍스트 에디터",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/teamsparta-biz/rich-editor.git",
    "directory": "packages/rich-editor"
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build && tsup && node -e \"require('fs').copyFileSync('src/styles.css','dist/styles.css')\"",
    "typecheck": "tsc --noEmit",
    "check:dist": "node scripts/check-dist.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build && pnpm check:dist && pnpm test"
  },
  "peerDependencies": {
    "@tiptap/core": "^2",
    "@tiptap/react": "^2",
    "react": "^19",
    "react-dom": "^19",
    "tailwindcss": "^4"
  },
  "dependencies": {
    "@tiptap/extension-bullet-list": "^2",
    "@tiptap/extension-code-block-lowlight": "^2",
    "@tiptap/extension-document": "^2",
    "@tiptap/extension-heading": "^2",
    "@tiptap/extension-history": "^2",
    "@tiptap/extension-image": "^2",
    "@tiptap/extension-link": "^2",
    "@tiptap/extension-list-item": "^2",
    "@tiptap/extension-ordered-list": "^2",
    "@tiptap/extension-paragraph": "^2",
    "@tiptap/extension-placeholder": "^2",
    "@tiptap/extension-table": "^2",
    "@tiptap/extension-table-cell": "^2",
    "@tiptap/extension-table-header": "^2",
    "@tiptap/extension-table-row": "^2",
    "@tiptap/extension-task-item": "^2",
    "@tiptap/extension-task-list": "^2",
    "@tiptap/extension-text": "^2",
    "@tiptap/pm": "^2",
    "lowlight": "^3"
  },
  "devDependencies": {
    "@tiptap/core": "^2.10.3",
    "@tiptap/react": "^2.10.3",
    "@types/jsdom": "^21.1.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.3.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.9"
  }
}
